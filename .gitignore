# =========================
# Terraform
# =========================

# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Terraform plan files
*.tfplan

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file (optional - usually KEEP this)
# Uncomment if you don't want to commit it
# .terraform.lock.hcl

# =========================
# Environment / Secrets
# =========================

.env
.env.*
*.key
*.pem

# =========================
# OS / Editor files
# =========================

# Mac
.DS_Store

# VS Code
.vscode/

# JetBrains
.idea/

# Logs
*.log

*.terraform.lock.hcl